# ─────────────────────────────────────────────
#  Suraksha — backend/.env.example
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

PORT=3000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://kumarsiddharth166:DarkSider@clusterone.bqlr6.mongodb.net/suraksha?retryWrites=true&w=majority

# Pinata IPFS — https://app.pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Polygon Mumbai testnet
# RPC URL from: https://maticvigil.com  or  https://rpc.ankr.com/polygon_mumbai
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com

# Your MetaMask wallet private key (no 0x prefix needed)
# ⚠️  NEVER commit this to git — .env is in .gitignore
DEPLOYER_PRIVATE_KEY=your_wallet_private_key_here

# Paste here after running: npx hardhat run deploy.js --network mumbai
CONTRACT_ADDRESS=deployed_evidence_registry_address

# Optional — only needed if you verify contract on Polygonscan
POLYGONSCAN_API_KEY=your_polygonscan_api_key